#!/usr/bin/env bash
# Run the same checks the remote CI runs, locally, in one command.
#
#   bin/ci
#
# Mirrors .github/workflows/ci.yml. Run it before pushing so what passes here
# passes there. Each check that needs a tool you don't have installed is
# skipped with a hint rather than failing the run (CI is the hard gate).
#
# Exit nonzero if any *runnable* check fails.
set -uo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

fail=0
section() { printf '\n\033[1m==> %s\033[0m\n' "$1"; }
skip()    { printf '    \033[33mskip:\033[0m %s\n' "$1"; }
ok()      { printf '    \033[32mok\033[0m\n'; }
bad()     { printf '    \033[31mFAIL\033[0m\n'; fail=1; }

section "web dependencies (npm ci)"
if command -v npm >/dev/null 2>&1; then
    (cd web && npm ci --no-audit --no-fund) && ok || bad
else
    skip "npm not found"
fi

# The Go packages embed web/.output/public (see web/embed.go), so a stale build
# here is silently baked into the binary: the UI you test is not the UI you
# wrote. Rebuild when the output is missing OR older than any web/ source —
# checking only for existence lets an old build pass as ok forever.
section "web assets (embed prerequisite)"
built=web/.output/public/index.html
if [ -e "$built" ] && [ -z "$(find web -type f -newer "$built" \
        -not -path 'web/node_modules/*' \
        -not -path 'web/.output/*' \
        -not -path 'web/.nuxt/*' \
        -print -quit)" ]; then
    ok
elif command -v npm >/dev/null 2>&1; then
    (cd web && npm run generate) && ok || bad
else
    mkdir -p web/.output/public
    printf '<!doctype html><title>Kernl</title>' > web/.output/public/index.html
    skip "npm not found — wrote a placeholder so the embed compiles"
fi

section "gofmt"
unformatted=$(gofmt -l $(git ls-files '*.go'))
if [ -n "$unformatted" ]; then
    echo "$unformatted" | sed 's/^/    /'
    bad
else
    ok
fi

section "go vet"
go vet ./... && ok || bad

section "golangci-lint"
if command -v golangci-lint >/dev/null 2>&1; then
    golangci-lint run ./... && ok || bad
else
    skip "golangci-lint not installed: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2"
fi

section "go test (unit)"
go test ./... && ok || bad

section "go test (integration contracts) — advisory, manual-only (see AGENTS.md §4)"
# Not part of the hard gate: needs a real bd. Full e2e tests are split behind
# extra tags: `bde2e` for bd fixture workflows and `realagent` for real agents.
if command -v bd >/dev/null 2>&1; then
    go test -tags=integration ./... || skip "integration failures above (advisory — real bd contract drift)"
else
    skip "bd not installed: go install github.com/gastownhall/beads@v1.0.4"
fi

section "web test (vitest)"
if command -v npm >/dev/null 2>&1; then
    (cd web && npm test) && ok || bad
else
    skip "npm not installed"
fi

section "govulncheck (dependency CVEs)"
if command -v govulncheck >/dev/null 2>&1; then
    govulncheck ./... && ok || bad
else
    skip "govulncheck not installed: go install golang.org/x/vuln/cmd/govulncheck@latest"
fi

section "gitleaks (secret scan)"
if command -v gitleaks >/dev/null 2>&1; then
    gitleaks detect --no-banner --redact --config .gitleaks.toml && ok || bad
else
    skip "gitleaks not installed: go install github.com/zricethezav/gitleaks/v8@latest"
fi

echo
# anti-slop gate: em-dash in prose + the tool-name leak. Canonical: llm-workflow bin/slop-guard.
echo "==> slop-guard"; bin/slop-guard || fail=1

if [ "$fail" -eq 0 ]; then
    printf '\033[32mbin/ci: all runnable checks passed.\033[0m\n'
else
    printf '\033[31mbin/ci: failures above.\033[0m\n'
fi
exit "$fail"
